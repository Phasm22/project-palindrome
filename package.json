{
  "name": "project-palindrome",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "agent": "./src/cli.ts"
  },
  "scripts": {
    "test": "bun test",
    "dev": "bun run src/cli.ts",
    "agent": "bun run src/cli.ts",
    "export-tools": "bun run src/utils/export-tool-schemas.ts",
    "pce:verify-dod": "bun run src/pce/verify-dod.ts",
    "pce:test-redaction": "bun run src/pce/cli.ts test-redaction",
    "pce:api": "bun run src/pce/api/main.ts",
    "pce:gold-path": "bun run scripts/run-gold-path.ts",
    "pce:provenance-audit": "bun run scripts/run-provenance-audit.ts",
    "pce:phase3-dod": "bun run scripts/run-phase3-dod.ts",
    "pce:ingest-proxmox": "bun run scripts/ingest-proxmox.ts",
    "pce:ingest-network": "bun run scripts/ingest-network.ts",
    "pce:ingest-firewall": "bun run scripts/ingest-firewall.ts",
    "pce:ingest-all": "bun run scripts/ingest-all.ts",
    "pce:debug-vector": "bun run src/pce/debug-vector.ts",
    "pce:check-indexed": "bun run src/pce/check-indexed.ts",
    "opnsense:generate-unified-schema": "bun run src/tools/opnsense/generate-unified-schema.ts",
    "services:start": "./scripts/start-services.sh",
    "services:stop": "./scripts/stop-services.sh",
    "services:status": "docker compose ps",
    "ollama:setup": "./scripts/ollama-setup.sh setup",
    "ollama:list": "./scripts/ollama-setup.sh list",
    "ollama:pull": "./scripts/ollama-setup.sh pull",
    "ollama:test": "./scripts/ollama-setup.sh test",
    "dashboard:serve": "bun run dashboard/serve.ts",
    "dashboard:build": "bunx --bun tailwindcss -i ./dashboard/css/input.css -o ./dashboard/css/styles.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "latest",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.9",
    "tailwindcss": "^4.1.17",
    "vitest": "^4.0.9",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.15.1",
    "@types/ssh2": "^1.15.5",
    "ai": "^5.0.93",
    "axios": "^1.13.2",
    "chroma-js": "^3.2.0",
    "cytoscape": "^3.33.1",
    "dotenv": "^17.2.3",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "neo4j-driver": "^6.0.1",
    "openai": "^6.9.0",
    "sigma": "^3.0.2",
    "ssh2": "^1.17.0",
    "zod": "^4.1.12"
  }
}
